{
  "installCommand": "bun install",
  "buildCommand": "bun run build:web",
  "outputDirectory": "apps/web/dist",
  "functions": {
    "api/[...path].ts": {
      "maxDuration": 300
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
