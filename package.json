{
  "name": "kairos",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:api": "bun run apps/local-api/src/cli.ts",
    "dev:web": "vite --config apps/web/vite.config.ts",
    "build:web": "vite build --config apps/web/vite.config.ts",
    "preview:web": "vite preview --config apps/web/vite.config.ts",
    "qa:ui": "bun run apps/web/qa-regression.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit && tsc --noEmit -p apps/web/tsconfig.json",
    "browser-use:local": "bash scripts/bu-local-profile.sh",
    "browser-use:local:chatgpt": "BROWSER_USE_PREFER_LIVE_PROFILE_FOR_CHATGPT=1 bun run browser-use:local",
    "browser-use:local:deepseek-v4-pro": "BROWSER_USE_PROVIDER=openrouter BROWSER_USE_LLM=deepseek/deepseek-v4-pro bun run browser-use:local",
    "browser-use:local:delete-chats": "BROWSER_USE_PROVIDER=openrouter BROWSER_USE_LLM=deepseek/deepseek-v4-pro bash scripts/bu-delete-chats.sh"
  },
  "dependencies": {
    "@langchain/core": "^1.0.0",
    "@langchain/langgraph": "^1.0.0",
    "@langchain/openrouter": "^0.2.4",
    "@openrouter/ai-sdk-provider": "^2.9.0",
    "@supabase/supabase-js": "^2.56.0",
    "ai": "^6.0.174",
    "exa-js": "^2.12.1",
    "react-select": "^5.10.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "twilio": "^6.0.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "playwright": "1.59.1",
    "typescript": "^5.9.0",
    "vite": "^8.0.10",
    "vitest": "^4.0.0"
  }
}
